server:
  port: 8080

spring:
  datasource:
    url: jdbc:mysql://101.42.14.127:3306/aqe?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
    username: root
    password: 123456
    driver-class-name: com.mysql.cj.jdbc.Driver

  rabbitmq:
    host: 101.42.14.127
    port: 5672
    username: auto-quote-engin
    password: auto-quote-engin
    virtual-host: /
    publisher-confirm-type: correlated
    publisher-returns: true
    listener:
      simple:
        concurrency: 8
        max-concurrency: 16
        prefetch: 200
        acknowledge-mode: manual
        default-requeue-rejected: false
        retry:
          enabled: false

  jpa:
    hibernate:
      ddl-auto: none
    show-sql: true

  flyway:
    enabled: true
    baseline-on-migrate: true
    locations: classpath:db/migration

logging:
  level:
    com.aqe: debug